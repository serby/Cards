opt_out_usage

default_platform(:ios)

platform :ios do
  desc "Build and run on simulator (picks first booted or default)"
  lane :sim do
    sh("bazel build //Cards:Cards")
    # Find a booted simulator or boot the first available iPhone
    sim_id = sh("xcrun simctl list devices booted -j | ruby -rjson -e 'puts JSON.parse(STDIN.read)[\"devices\"].values.flatten.select{|d| d[\"state\"]==\"Booted\"}.first&.dig(\"udid\") || \"\"'").strip
    if sim_id.empty?
      sim_id = sh("xcrun simctl list devices available -j | ruby -rjson -e 'puts JSON.parse(STDIN.read)[\"devices\"].values.flatten.select{|d| d[\"name\"].include?(\"iPhone\") && d[\"isAvailable\"]}.first[\"udid\"]'").strip
      sh("xcrun simctl boot #{sim_id}")
    end
    sh("xcrun simctl install #{sim_id} ../bazel-bin/Cards/Cards.ipa")
    sh("xcrun simctl launch #{sim_id} net.serby.Cards")
  end

  desc "Deploy to TestFlight"
  lane :deploy_alpha do
    sh("bazel build //Cards:Cards --ios_multi_cpus=arm64 --compilation_mode=opt")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "bazel-bin/Cards/Cards.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: "Bug fixes and improvements"
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :screenshots do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      force: true,
      overwrite_screenshots: true
    )
  end

  desc "Upload app metadata to App Store Connect"
  lane :metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true
    )
  end

  desc "Deploy to App Store"
  lane :release do
    sh("bazel build //Cards:Cards --ios_multi_cpus=arm64 --compilation_mode=opt")

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "bazel-bin/Cards/Cards.ipa",
      submit_for_review: true,
      automatic_release: true,
      force: true
    )
  end
end
