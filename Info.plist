<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- REQUIRED: Bundle identification -->
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	
	<!-- Export compliance - no encryption used -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	
	<!-- REQUIRED: Version information -->
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>29</string>
	
	<!-- REQUIRED: Display names -->
	<key>CFBundleName</key>
	<string>Card Barcodes</string>
	<key>CFBundleDisplayName</key>
	<string>Card Barcodes</string>
	
	<!-- REQUIRED: iOS app marker -->
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<!-- REQUIRED: Privacy - Camera usage description -->
	<key>NSCameraUsageDescription</key>
	<string>Camera is used to scan barcodes on your loyalty and membership cards</string>
	
	<!-- REQUIRED: Device capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	
	<!-- REQUIRED: Supported orientations (iPhone only, portrait) -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIRequiresFullScreen</key>
	<true/>
	
	<!-- REQUIRED: Launch screen -->
	<key>UILaunchScreen</key>
	<dict/>
	
	<!-- Scene configuration -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	
	<!-- URL scheme for deep linking -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>net.serby.Cards</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>cards</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
